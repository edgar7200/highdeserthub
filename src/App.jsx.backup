}

.listings-count strong {
  color: var(--ink);
  font-weight: 700;
}

.filter-pills {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.pill {
  background: var(--cream);
  border: 1.5px solid #E8DDD0;
  color: var(--ink);
  padding: 0.4rem 1rem;
  border-radius: 2rem;
  font-size: 0.8rem;
  font-weight: 500;
  cursor: pointer;
