}

.btn-secondary:hover { border-color: var(--ink); }

/* CTA BANNER */
.cta-banner {
  background: var(--navy);
  padding: 4rem 2rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-banner::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 100% at 50% 50%, rgba(196,96,58,0.12) 0%, transparent 70%);
